# Flask settings
FLASK_APP=run.py
FLASK_DEBUG=1

# Database settings
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Consult team leads for full values
# Postgres Credentials
POSTGRES_USER=your-postgres-username
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=your-postgres-database-name

# Clerk settings
CLERK_ISSUER=https://...
CLERK_AUDIENCE=https://...
CLERK_FRONTEND_API=https://...
CLERK_JWKS_URL=https://...
CLERK_SECRET_KEY=your-clerk-secret-key

# Optional debug settings
# WARNING: NEVER set DEBUG=True in production! This enables the interactive
# debugger and exposes sensitive information. Set to False for production.
DEBUG=True
